# Core
DATABASE_URL=postgresql://postgres:password@localhost:5432/offchain
JWT_SECRET=replace-with-a-long-random-secret

# Google Maps
GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
GOOGLE_MAPS_DEFAULT_COUNTRY=in
GOOGLE_MAPS_TIMEOUT_SECONDS=8

# Pricing defaults
BASE_FARE_WEI=200000000000000
PER_KM_RATE_WEI=70000000000000
PER_MIN_RATE_WEI=10000000000000
SERVICE_FEE_PERCENT=5
MIN_FARE_WEI=250000000000000
SURGE_MULTIPLIER=1.0
CEILING_BOND_PERCENT=20

# Contract + signing
CARPOOL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=replace-with-treasury-private-key

# Chain sync (optional)
CHAIN_RPC_URL=
