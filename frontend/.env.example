# Local-only — copy to .env and fill in your values.
# Backend API base URL (FastAPI)
VITE_BACKEND_BASE_URL=http://localhost:8000/api/v1

# Map provider: "google" (default) or "maplibre" (free OSM, no key needed)
VITE_MAP_PROVIDER=google

# Required only when VITE_MAP_PROVIDER=google
# Get one at https://console.cloud.google.com/google/maps-apis
# Enable: "Maps JavaScript API" + "Directions API"
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
